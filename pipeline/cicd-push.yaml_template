apiVersion: tekton.dev/v1beta1
kind: PipelineRun
metadata:
  name: build-push-deploy-pipelinerun
  namespace: {{NAMESPACE}}
spec:
  pipelineRef:
    name: build-push-deploy-pipeline
  serviceAccountName: pipeline-admin
  workspaces:
    - name: git-ws
      persistentvolumeclaim:
        claimName: git-source-workspace2
  params:
    - name: git-source-url
      value: "{{SRCREPO}}"
    - name: git-target-url
      value: "{{TRGTREPO}}"
    - name: git-revision
      value: "{{BRANCH}}"
    - name: dockerfile-path
      value: docker/oc-cli-git
    - name: image-name
      value: oc-cli-git
    - name: image-tag
      value: latest
    - name: image-namespace
      value: {{NAMESPACE}}
